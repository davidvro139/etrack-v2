{
  "name": "etrack-v2-server",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "sequelize": "^6.37.3",
    "mysql2": "^3.11.0",
    "axios": "^1.7.2",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "sqlite3": "^5.1.7",
    "cross-env": "^7.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "setupFiles": ["./src/__tests__/setEnv.js"],
    "setupFilesAfterEnv": ["./src/__tests__/setup.js"]
  }
}
